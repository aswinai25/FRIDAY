# Flask Environment
FLASK_ENV=production
FLASK_DEBUG=False

# Server Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# CORS Configuration (comma-separated, or * for all)
ALLOWED_ORIGINS=*

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5000

# Logging
LOG_LEVEL=INFO

# Security (for production, change these!)
SECRET_KEY=your-secret-key-here-change-in-production
